{
  "name": "n8n-node-mocker",
  "version": "0.1.0",
  "description": "MITM proxy + webhook simulator for testing n8n nodes without real API credentials",
  "type": "module",
  "bin": {
    "n8n-node-mocker": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/templates dist/",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "n8n",
    "mock",
    "proxy",
    "webhook",
    "testing"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "node-forge": "^1.4.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/node-forge": "^1.3.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
